    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^26.1.0",
    "cpy-cli": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
